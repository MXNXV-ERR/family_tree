rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Per-user family index that powers the family switcher.
    // users/{uid}/families/{treeId} -> { treeId, role, name, mono, color }
    // A user manages their own index; the tree OWNER may also write it, so that
    // promoting/demoting a collaborator can sync that collaborator's role here.
    match /users/{userId}/families/{treeId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        ( exists(/databases/$(database)/documents/trees/$(treeId)/memberships/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/trees/$(treeId)/memberships/$(request.auth.uid)).data.role in ['owner', 'coowner'] ) ||
        ( exists(/databases/$(database)/documents/trees/$(treeId)) &&
          get(/databases/$(database)/documents/trees/$(treeId)).data.ownerUid == request.auth.uid )
      );
    }

    // Per-user profile doc (users/{uid}) — the user owns their own profile only.
    // Matches the document itself, not the /families/* subcollection rule above.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Per-user master (combined-family) index — the switcher list. Self only.
    match /users/{userId}/masters/{masterId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Master families (virtual overlays). Owner-private in v1: only the creator
    // can read/write. The doc holds constituent treeIds + bridge links only —
    // the actual member/relationship data stays in the trees the master
    // references, each still guarded by its own /trees rules above.
    match /masters/{masterId} {
      allow read, update, delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
    }

    match /trees/{treeId} {
      function signedIn() { return request.auth != null; }
      function uid() { return request.auth.uid; }

      // --- role resolution (membership doc is the source of truth) ---
      function memPath(u) { return /databases/$(database)/documents/trees/$(treeId)/memberships/$(u); }
      function hasMem(u) { return exists(memPath(u)); }
      // Legacy single tree (treeId === ownerUid) has no membership doc → owner.
      function roleOf(u) { return hasMem(u) ? get(memPath(u)).data.role : (u == treeId ? 'owner' : 'none'); }
      function myRole() { return roleOf(uid()); }
      function isOwnerRole() {
        return signedIn() && (
          uid() == treeId ||
          myRole() == 'owner' ||
          (treeExists() && treeData().ownerUid == uid())
        );
      }
      function isCoOwnerRole() { return signedIn() && myRole() == 'coowner'; }
      // Owner + co-owner: every owner power EXCEPT deleting the tree / demoting
      // the founding owner (those stay isOwnerRole-only).
      function hasOwnerPowers() { return isOwnerRole() || isCoOwnerRole(); }
      function isAdminRole() { return signedIn() && myRole() == 'admin'; }
      // Owner + co-owner + admin have full data control.
      function canManageData() { return hasOwnerPowers() || isAdminRole(); }

      // --- membership / access (tree-doc scope: `resource` is the tree) ---
      function isMember() {
        return signedIn() && (
          uid() == treeId ||
          hasMem(uid()) ||
          (resource != null && 'allowedUsers' in resource.data && uid() in resource.data.allowedUsers) ||
          (resource != null && 'ownerUid' in resource.data && resource.data.ownerUid == uid())
        );
      }
      // Web app join: append yourself to allowedUsers with the right invite code.
      function isJoining() {
        return signedIn() &&
               request.resource.data.diff(resource.data).affectedKeys().hasOnly(['allowedUsers']) &&
               request.resource.data.inviteCode == resource.data.inviteCode;
      }

      // --- subcollection helpers (tree doc is NOT in scope here) ---
      function treeExists() { return exists(/databases/$(database)/documents/trees/$(treeId)); }
      function treeData() { return get(/databases/$(database)/documents/trees/$(treeId)).data; }
      function isMemberHere() {
        return signedIn() && (
          uid() == treeId ||
          hasMem(uid()) ||
          (treeExists() && treeData().ownerUid == uid()) ||
          (treeExists() && 'allowedUsers' in treeData() && uid() in treeData().allowedUsers)
        );
      }
      // Depth-1: is member `mid` the node linked to the signed-in user's account?
      function memberOwnedByMe(mid) {
        return exists(/databases/$(database)/documents/trees/$(treeId)/members/$(mid)) &&
          get(/databases/$(database)/documents/trees/$(treeId)/members/$(mid)).data.associatedUserId == uid();
      }
      function ownsTreeDoc() { return treeExists() && treeData().ownerUid == uid(); }

      // Members read their tree by id; invite-code joins use the collection query
      // (allow list) below, which doesn't need broad per-doc read access.
      allow get: if isMember();
      allow list: if signedIn();  // query trees by inviteCode to join (residual: enumerable — mitigated by App Check)
      allow create: if signedIn() && (uid() == treeId || request.resource.data.ownerUid == uid());
      allow update: if isMember() || isJoining() || isOwnerRole();
      allow delete: if isOwnerRole();

      // Collaborators / membership records.
      match /memberships/{memberUid} {
        allow read: if isMemberHere();
        // No blanket self-serve member join. A creator seeds their OWN 'owner'
        // membership; an owner/admin creates a member's membership after approving
        // a join request; and 'open' joinPolicy families (incl. legacy trees with
        // no joinPolicy field) still allow instant self-join.
        allow create: if signedIn() && (
          (memberUid == uid() && request.resource.data.role == 'owner') ||
          (canManageData() && request.resource.data.role == 'member') ||
          (memberUid == uid() && request.resource.data.role == 'member' &&
            treeExists() &&
            (!('joinPolicy' in treeData()) || treeData().joinPolicy == 'open'))
        );
        // Owner/co-owner promote/demote (admin|member|coowner — never the founder,
        // never reassigns 'owner'). A user may patch their own doc without role change.
        allow update: if signedIn() && (
          (hasOwnerPowers() && resource.data.role != 'owner' && request.resource.data.role in ['admin', 'member', 'coowner']) ||
          (memberUid == uid() && request.resource.data.role == resource.data.role)
        );
        allow delete: if signedIn() && ((hasOwnerPowers() && resource.data.role != 'owner') || memberUid == uid());
      }

      // Join requests (approval joinPolicy). A user creates/cancels their own
      // pending request; an owner/admin reads all + approves/rejects.
      match /joinRequests/{requestUid} {
        allow read: if signedIn() && (requestUid == uid() || canManageData());
        allow create: if signedIn() && requestUid == uid()
          && request.resource.data.status == 'pending';
        allow update: if signedIn() && (
          canManageData() ||
          (requestUid == uid() && request.resource.data.status == 'pending')
        );
        allow delete: if signedIn() && (requestUid == uid() || canManageData());
      }

      // Family events (timeline). Members read; owner/admin write.
      match /events/{eventId} {
        allow read: if isMemberHere();
        allow create, update, delete: if canManageData();
      }

      // Notes addressed to a member NODE. Anyone in the tree may send to any
      // member; only the sender and the user who has CLAIMED the recipient node
      // (memberOwnedByMe → "This is me") can read it. Create just needs a valid
      // sender + an existing target node. Recipient flips `read`; either deletes.
      match /notes/{noteId} {
        allow read: if signedIn() && (resource.data.fromUid == uid() || memberOwnedByMe(resource.data.toMemberId));
        allow create: if signedIn() && isMemberHere()
          && request.resource.data.fromUid == uid()
          && exists(/databases/$(database)/documents/trees/$(treeId)/members/$(request.resource.data.toMemberId));
        allow update: if signedIn() && memberOwnedByMe(resource.data.toMemberId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'reaction']);
        allow delete: if signedIn() && (resource.data.fromUid == uid() || memberOwnedByMe(resource.data.toMemberId));
      }

      // Members: owner/admin manage everyone; a normal member may add nodes
      // (to attach a relative) and edit ONLY their own linked node.
      match /members/{mid} {
        allow read: if isMemberHere();
        allow create: if isMemberHere();
        allow update: if canManageData()
          || (
            resource.data.associatedUserId == uid() &&
            request.resource.data.associatedUserId == resource.data.associatedUserId
          )
          // "This is me": a member may claim a node that has no owner yet by
          // setting associatedUserId to themselves — and changing nothing else.
          || (
            isMemberHere() &&
            (!('associatedUserId' in resource.data) || resource.data.associatedUserId == '') &&
            request.resource.data.associatedUserId == uid() &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['associatedUserId'])
          );
        allow delete: if canManageData();
      }

      // Activity trail (who changed what). Any member appends their OWN entry;
      // entries are immutable (no edit/delete — owner deletes the whole tree).
      match /activity/{entryId} {
        allow read: if isMemberHere();
        allow create: if isMemberHere() && request.resource.data.uid == uid();
        allow update, delete: if false;
      }

      // Relationships: owner/admin link anyone; a normal member may only
      // add/remove edges that touch their own node (depth 1).
      match /relationships/{rid} {
        allow read: if isMemberHere();
        allow create: if canManageData() ||
          memberOwnedByMe(request.resource.data.fromId) || memberOwnedByMe(request.resource.data.toId);
        allow update: if canManageData() ||
          memberOwnedByMe(request.resource.data.fromId) || memberOwnedByMe(request.resource.data.toId);
        allow delete: if canManageData() ||
          memberOwnedByMe(resource.data.fromId) || memberOwnedByMe(resource.data.toId);
      }
    }
  }
}
