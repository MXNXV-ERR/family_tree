rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /trees/{treeId} {
      // 1. Ownership & Membership Check
      function isMember() {
        return request.auth != null && (
          request.auth.uid == treeId || 
          request.auth.uid in resource.data.allowedUsers
        );
      }

      // 2. Join Check (Updating allowedUsers with correct inviteCode)
      function isJoining() {
        return request.auth != null && 
               request.resource.data.diff(resource.data).affectedKeys().hasOnly(['allowedUsers']) &&
               request.resource.data.inviteCode == resource.data.inviteCode;
      }

      allow get: if request.auth != null; // Allow reading specific tree to join
      allow list: if isMember(); // Only members can query

      allow create: if request.auth.uid == treeId;
      allow update: if isMember() || isJoining();

      match /{document=**} {
        allow read, write: if get(/databases/$(database)/documents/trees/$(treeId)).data.allowedUsers.hasAny([request.auth.uid]) || request.auth.uid == treeId;
      }
    }
  }
}
