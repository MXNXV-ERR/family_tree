rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Per-user family index that powers the mobile family switcher.
    // users/{uid}/families/{treeId} -> { treeId, role, name, mono, color }
    match /users/{userId}/families/{treeId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /trees/{treeId} {
      function signedIn() { return request.auth != null; }
      // Legacy convention: a tree whose id equals the owner's uid.
      function isLegacyOwner() { return signedIn() && request.auth.uid == treeId; }
      // New convention: tree carries an explicit ownerUid field.
      function isTreeOwner() { return signedIn() && resource.data.ownerUid == request.auth.uid; }
      // A member is the owner, an allowedUsers entry (web app), or has a
      // membership doc under this tree (mobile multi-family).
      function isMember() {
        return signedIn() && (
          request.auth.uid == treeId ||
          (resource != null && 'allowedUsers' in resource.data && request.auth.uid in resource.data.allowedUsers) ||
          exists(/databases/$(database)/documents/trees/$(treeId)/memberships/$(request.auth.uid))
        );
      }
      // Web app join: append yourself to allowedUsers with the right invite code.
      function isJoining() {
        return signedIn() &&
               request.resource.data.diff(resource.data).affectedKeys().hasOnly(['allowedUsers']) &&
               request.resource.data.inviteCode == resource.data.inviteCode;
      }

      allow get: if signedIn();   // read a tree (also used to look up an invite)
      allow list: if signedIn();  // query trees by inviteCode to join
      allow create: if signedIn() && (request.auth.uid == treeId || request.resource.data.ownerUid == request.auth.uid);
      allow update: if isMember() || isJoining() || isTreeOwner();
      allow delete: if isLegacyOwner() || isTreeOwner();

      // Collaborators / membership records.
      match /memberships/{memberUid} {
        allow read: if signedIn();
        allow create, update, delete: if signedIn() && (
          memberUid == request.auth.uid || request.auth.uid == treeId || isTreeOwner()
        );
      }

      // Tree data.
      match /members/{document=**} {
        allow read, write: if isMember();
      }
      match /relationships/{document=**} {
        allow read, write: if isMember();
      }
    }
  }
}
