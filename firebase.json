{
    "firestore": {
        "rules": "firestore.rules"
    },
    "storage": {
        "rules": "storage.rules"
    },
    "hosting": {
        "public": "mobile/dist",
        "ignore": ["firebase.json", "**/.*"],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ],
        "headers": [
            {
                "source": "**/*.@(js|css|woff2)",
                "headers": [
                    { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
                ]
            }
        ]
    }
}
